# 火山方舟 API Key（在控制台 https://console.volcengine.com/ark 获取）
ARK_API_KEY=your_ark_api_key_here

# 模型名称（直接使用模型名，无需创建接入点）
DOUBAO_MODEL=doubao-seed-2-lite-250520

# mT5小模型本地路径或 HuggingFace 模型ID
REWRITER_MODEL_ID=google/mt5-small
LOCAL_MODEL_PATH=models/mt5_small_rewriter

# ONNX量化模型导出目录
REWRITER_ONNX_DIR=/tmp/mt5_small_onnx

# 是否使用ONNX量化推理（推荐true以降低延迟）
USE_ONNX=true

# 评测LLM打分采样率（0~1，降低API费用）
LLM_SCORE_SAMPLE_RATE=0.3
